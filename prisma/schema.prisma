generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model banner {
  id          String   @id
  title       String
  description String
  image       String?
  ctaText     String
  ctaLink     String
  bgColor     String   @default("#006B3F")
  textColor   String   @default("#FFFFFF")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([isActive], map: "Banner_isActive_idx")
  @@index([order], map: "Banner_order_idx")
}

model buyer {
  id           String        @id
  userId       String        @unique(map: "Buyer_userId_key")
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  dateOfBirth  DateTime?
  preferences  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  user         user          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Buyer_userId_fkey")
  buyermetrics buyermetrics?
  cart         cart?
  order        order[]
  wishlist     wishlist[]

  @@index([userId], map: "Buyer_userId_idx")
}

model buyermetrics {
  id                 String   @id
  buyerId            String   @unique(map: "BuyerMetrics_buyerId_key")
  totalOrders        Int      @default(0)
  totalSpent         Float    @default(0)
  averageOrderValue  Float    @default(0)
  favoriteCategories String?
  lastUpdated        DateTime @default(now())
  buyer              buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade, map: "BuyerMetrics_buyerId_fkey")

  @@index([buyerId], map: "BuyerMetrics_buyerId_idx")
}

model cart {
  id        String     @id
  buyerId   String     @unique(map: "Cart_buyerId_key")
  sessionId String?
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  buyer     buyer      @relation(fields: [buyerId], references: [id], onDelete: Cascade, map: "Cart_buyerId_fkey")
  cartitem  cartitem[]

  @@index([expiresAt], map: "Cart_expiresAt_idx")
  @@index([sessionId], map: "Cart_sessionId_idx")
}

model cartitem {
  id        String   @id
  cartId    String
  productId String
  quantity  Int      @default(1)
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime
  cart      cart     @relation(fields: [cartId], references: [id], onDelete: Cascade, map: "CartItem_cartId_fkey")
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "CartItem_productId_fkey")

  @@unique([cartId, productId], map: "CartItem_cartId_productId_key")
  @@index([cartId], map: "CartItem_cartId_idx")
  @@index([productId], map: "CartItem_productId_idx")
}

model category {
  id              String     @id
  name            String
  slug            String     @unique(map: "Category_slug_key")
  description     String?
  image           String?
  icon            String?
  parentId        String?
  isActive        Boolean    @default(true)
  sortOrder       Int        @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime
  category        category?  @relation("categoryTocategory", fields: [parentId], references: [id], map: "Category_parentId_fkey")
  other_category  category[] @relation("categoryTocategory")
  product         product[]

  @@index([isActive], map: "Category_isActive_idx")
  @@index([parentId], map: "Category_parentId_idx")
  @@index([slug], map: "Category_slug_idx")
  @@index([sortOrder], map: "Category_sortOrder_idx")
}

model conversation {
  id                               String    @id
  buyerId                          String
  sellerId                         String
  productId                        String?
  orderId                          String?
  status                           String    @default("active")
  createdAt                        DateTime  @default(now())
  updatedAt                        DateTime
  user_conversation_buyerIdTouser  user      @relation("conversation_buyerIdTouser", fields: [buyerId], references: [id], onDelete: Cascade, map: "Conversation_buyerId_fkey")
  order                            order?    @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "Conversation_orderId_fkey")
  product                          product?  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "Conversation_productId_fkey")
  user_conversation_sellerIdTouser user      @relation("conversation_sellerIdTouser", fields: [sellerId], references: [id], onDelete: Cascade, map: "Conversation_sellerId_fkey")
  message                          message[]

  @@unique([buyerId, sellerId], map: "Conversation_buyerId_sellerId_key")
  @@index([buyerId], map: "Conversation_buyerId_idx")
  @@index([orderId], map: "Conversation_orderId_idx")
  @@index([productId], map: "Conversation_productId_idx")
  @@index([sellerId], map: "Conversation_sellerId_idx")
  @@index([status], map: "Conversation_status_idx")
}

model message {
  id             String       @id
  content        String
  type           String       @default("text")
  senderId       String
  conversationId String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  conversation   conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "Message_conversationId_fkey")
  user           user         @relation(fields: [senderId], references: [id], onDelete: Cascade, map: "Message_senderId_fkey")

  @@index([conversationId], map: "Message_conversationId_idx")
  @@index([read], map: "Message_read_idx")
  @@index([senderId], map: "Message_senderId_idx")
}

model notification {
  id        String   @id
  userId    String
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Notification_userId_fkey")

  @@index([createdAt], map: "Notification_createdAt_idx")
  @@index([isRead], map: "Notification_isRead_idx")
  @@index([type], map: "Notification_type_idx")
  @@index([userId], map: "Notification_userId_idx")
}

model order {
  id                 String               @id
  orderNumber        String               @unique(map: "Order_orderNumber_key")
  buyerId            String
  sellerId           String
  status             order_status         @default(PENDING)
  currency           String               @default("USD")
  subtotal           Float
  taxAmount          Float                @default(0)
  shippingAmount     Float                @default(0)
  discountAmount     Float                @default(0)
  totalAmount        Float
  shippingAddress    String?
  billingAddress     String?
  trackingNumber     String?
  notes              String?
  internalNotes      String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  conversation       conversation[]
  buyer              buyer                @relation(fields: [buyerId], references: [id], onDelete: Cascade, map: "Order_buyerId_fkey")
  seller             seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade, map: "Order_sellerId_fkey")
  orderitem          orderitem[]
  orderstatushistory orderstatushistory[]
  payment            payment?

  @@index([buyerId], map: "Order_buyerId_idx")
  @@index([createdAt], map: "Order_createdAt_idx")
  @@index([sellerId], map: "Order_sellerId_idx")
  @@index([status], map: "Order_status_idx")
}

model orderitem {
  id              String   @id
  orderId         String
  productId       String
  quantity        Int
  price           Float
  total           Float
  productSnapshot String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  order           order    @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "OrderItem_orderId_fkey")
  product         product  @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_idx")
  @@index([productId], map: "OrderItem_productId_idx")
}

model orderstatushistory {
  id        String                    @id
  orderId   String
  status    orderstatushistory_status
  notes     String?
  changedBy String?
  createdAt DateTime                  @default(now())
  order     order                     @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "OrderStatusHistory_orderId_fkey")

  @@index([createdAt], map: "OrderStatusHistory_createdAt_idx")
  @@index([orderId], map: "OrderStatusHistory_orderId_idx")
  @@index([status], map: "OrderStatusHistory_status_idx")
}

model payment {
  id                    String         @id
  userId                String
  subscriptionId        String?        @unique(map: "Payment_subscriptionId_key")
  orderId               String?        @unique(map: "Payment_orderId_key")
  amount                Float
  currency              String         @default("USD")
  status                payment_status @default(PENDING)
  paymentMethod         String
  transactionId         String?
  stripePaymentIntentId String?
  gatewayResponse       String?        @db.Text
  description           String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime
  order                 order?         @relation(fields: [orderId], references: [id], map: "Payment_orderId_fkey")
  subscription          subscription?  @relation(fields: [subscriptionId], references: [id], map: "Payment_subscriptionId_fkey")
  user                  user           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Payment_userId_fkey")

  @@index([createdAt], map: "Payment_createdAt_idx")
  @@index([orderId], map: "Payment_orderId_idx")
  @@index([status], map: "Payment_status_idx")
  @@index([subscriptionId], map: "Payment_subscriptionId_idx")
  @@index([userId], map: "Payment_userId_idx")
}

model payoutrequest {
  id             String               @id
  walletId       String
  amount         Float
  status         payoutrequest_status @default(PENDING)
  paymentMethod  String
  paymentDetails String
  reference      String?
  adminNotes     String?
  processedAt    DateTime?
  processedBy    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime
  sellerwallet   sellerwallet         @relation(fields: [walletId], references: [id], onDelete: Cascade, map: "PayoutRequest_walletId_fkey")

  @@index([createdAt], map: "PayoutRequest_createdAt_idx")
  @@index([status], map: "PayoutRequest_status_idx")
  @@index([walletId], map: "PayoutRequest_walletId_idx")
}

model product {
  id               String            @id
  sellerId         String
  categoryId       String
  sku              String?           @unique(map: "Product_sku_key")
  name             String
  slug             String            @unique(map: "Product_slug_key")
  description      String?
  shortDescription String?
  price            Float
  discountPrice    Float?
  costPrice        Float?
  weight           Float?
  dimensions       String?
  images           String?
  videos           String?
  tags             String?
  condition        product_condition @default(NEW)
  minStock         Int               @default(0)
  stock            Int               @default(0)
  soldCount        Int               @default(0)
  courierAvailable Boolean           @default(false)
  courierPrice     Float?
  isActive         Boolean           @default(true)
  isFeatured       Boolean           @default(false)
  rating           Float             @default(0)
  totalReviews     Int               @default(0)
  locationCity     String?
  locationDistrict String?
  locationRegion   String?
  locationAddress  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  cartitem         cartitem[]
  conversation     conversation[]
  orderitem        orderitem[]
  category         category          @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "Product_categoryId_fkey")
  seller           seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade, map: "Product_sellerId_fkey")
  productmetrics   productmetrics?
  review           review[]
  wishlistitem     wishlistitem[]

  @@index([categoryId], map: "Product_categoryId_idx")
  @@index([createdAt], map: "Product_createdAt_idx")
  @@index([isActive], map: "Product_isActive_idx")
  @@index([isFeatured], map: "Product_isFeatured_idx")
  @@index([locationCity], map: "Product_locationCity_idx")
  @@index([locationDistrict], map: "Product_locationDistrict_idx")
  @@index([locationRegion], map: "Product_locationRegion_idx")
  @@index([price], map: "Product_price_idx")
  @@index([sellerId], map: "Product_sellerId_idx")
}

model productmetrics {
  id             String   @id
  productId      String   @unique(map: "ProductMetrics_productId_key")
  viewCount      Int      @default(0)
  cartAdds       Int      @default(0)
  purchaseCount  Int      @default(0)
  revenue        Float    @default(0)
  conversionRate Float    @default(0)
  averageRating  Float    @default(0)
  lastUpdated    DateTime @default(now())
  product        product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductMetrics_productId_fkey")

  @@index([productId], map: "ProductMetrics_productId_idx")
}

model promotion {
  id                   String   @id
  sellerId             String
  name                 String
  description          String
  type                 String
  value                Float
  minOrderAmount       Float?   @default(0)
  maxDiscountAmount    Float?   @default(0)
  applicableProducts   String?  @default("[]")
  applicableCategories String?  @default("[]")
  startDate            DateTime
  endDate              DateTime
  isActive             Boolean  @default(true)
  usageCount           Int      @default(0)
  usageLimit           Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  seller               seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade, map: "Promotion_sellerId_fkey")

  @@index([endDate], map: "Promotion_endDate_idx")
  @@index([isActive], map: "Promotion_isActive_idx")
  @@index([sellerId], map: "Promotion_sellerId_idx")
  @@index([startDate], map: "Promotion_startDate_idx")
}

model review {
  id             String   @id
  productId      String
  userId         String
  orderId        String?
  rating         Int
  title          String?
  comment        String?
  images         String?
  sellerResponse String?
  isVerified     Boolean  @default(false)
  isApproved     Boolean  @default(false)
  helpfulCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  product        product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "Review_productId_fkey")
  user           user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Review_userId_fkey")

  @@unique([productId, userId], map: "Review_productId_userId_key")
  @@index([isApproved], map: "Review_isApproved_idx")
  @@index([productId], map: "Review_productId_idx")
  @@index([rating], map: "Review_rating_idx")
  @@index([userId], map: "Review_userId_idx")
}

model seller {
  id                  String         @id
  userId              String         @unique(map: "Seller_userId_key")
  businessName        String
  businessDescription String?
  businessImage       String?
  businessEmail       String?
  businessPhone       String?
  website             String?
  address             String?
  city                String?
  state               String?
  country             String?
  postalCode          String?
  taxId               String?
  profileImage        String?
  bio                 String?
  verificationStatus  String         @default("PENDING")
  isActive            Boolean        @default(true)
  rating              Float?         @default(0)
  totalReviews        Int            @default(0)
  foundedYear         Int?
  teamSize            Int?
  businessType        String?
  specialties         String?
  certifications      String?
  responseTime        Float?
  responseRate        Float?         @default(0)
  returnPolicy        String?
  shippingInfo        String?
  socialLinks         String?
  showcaseImages      String?
  achievements        String?
  languages           String?
  workingHours        String?
  isFeatured          Boolean        @default(false)
  badgeLevel          String         @default("BRONZE")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime
  order               order[]
  product             product[]
  promotion           promotion[]
  user                user           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Seller_userId_fkey")
  sellermetrics       sellermetrics?
  sellerwallet        sellerwallet?
  subscription        subscription?

  @@index([badgeLevel], map: "Seller_badgeLevel_idx")
  @@index([isActive], map: "Seller_isActive_idx")
  @@index([isFeatured], map: "Seller_isFeatured_idx")
  @@index([rating], map: "Seller_rating_idx")
  @@index([userId], map: "Seller_userId_idx")
  @@index([verificationStatus], map: "Seller_verificationStatus_idx")
}

model sellermetrics {
  id             String   @id
  sellerId       String   @unique(map: "SellerMetrics_sellerId_key")
  totalRevenue   Float    @default(0)
  totalOrders    Int      @default(0)
  totalProducts  Int      @default(0)
  averageRating  Float    @default(0)
  conversionRate Float    @default(0)
  lastUpdated    DateTime @default(now())
  seller         seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade, map: "SellerMetrics_sellerId_fkey")

  @@index([sellerId], map: "SellerMetrics_sellerId_idx")
}

model sellerwallet {
  id                String              @id
  sellerId          String              @unique(map: "SellerWallet_sellerId_key")
  availableBalance  Float               @default(0)
  pendingBalance    Float               @default(0)
  totalEarnings     Float               @default(0)
  totalWithdrawn    Float               @default(0)
  lastUpdated       DateTime            @default(now())
  payoutrequest     payoutrequest[]
  seller            seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade, map: "SellerWallet_sellerId_fkey")
  wallettransaction wallettransaction[]

  @@index([sellerId], map: "SellerWallet_sellerId_idx")
}

model subscription {
  id               String              @id
  sellerId         String              @unique(map: "Subscription_sellerId_key")
  planId           String
  status           subscription_status @default(ACTIVE)
  startDate        DateTime            @default(now())
  endDate          DateTime
  autoRenew        Boolean             @default(true)
  cancelledAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime
  payment          payment?
  subscriptionplan subscriptionplan    @relation(fields: [planId], references: [id], map: "Subscription_planId_fkey")
  seller           seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade, map: "Subscription_sellerId_fkey")

  @@index([endDate], map: "Subscription_endDate_idx")
  @@index([planId], map: "Subscription_planId_idx")
  @@index([sellerId], map: "Subscription_sellerId_idx")
  @@index([status], map: "Subscription_status_idx")
}

model subscriptionplan {
  id           String         @id
  name         String
  description  String?
  monthlyPrice Float
  yearlyPrice  Float?
  maxProducts  Int            @default(100)
  maxOrders    Int            @default(-1)
  features     String?
  isActive     Boolean        @default(true)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  subscription subscription[]

  @@index([isActive], map: "SubscriptionPlan_isActive_idx")
  @@index([sortOrder], map: "SubscriptionPlan_sortOrder_idx")
}

model user {
  id                                       String         @id
  name                                     String?
  email                                    String         @unique(map: "User_email_key")
  emailVerified                            Boolean        @default(false)
  role                                     user_role
  password                                 String
  profileImage                             String?
  phone                                    String?
  isActive                                 Boolean        @default(true)
  lastLoginAt                              DateTime?
  resetToken                               String?
  resetTokenExpires                        DateTime?
  emailVerificationToken                   String?
  emailVerificationExpires                 DateTime?
  activationToken                          String?
  activationTokenExpires                   DateTime?
  createdAt                                DateTime       @default(now())
  updatedAt                                DateTime
  buyer                                    buyer?
  conversation_conversation_buyerIdTouser  conversation[] @relation("conversation_buyerIdTouser")
  conversation_conversation_sellerIdTouser conversation[] @relation("conversation_sellerIdTouser")
  message                                  message[]
  notification                             notification[]
  payment                                  payment[]
  review                                   review[]
  seller                                   seller?
}

model wallettransaction {
  id           String                 @id
  walletId     String
  type         wallettransaction_type
  amount       Float
  balance      Float
  description  String?
  reference    String?
  metadata     String?
  createdAt    DateTime               @default(now())
  sellerwallet sellerwallet           @relation(fields: [walletId], references: [id], onDelete: Cascade, map: "WalletTransaction_walletId_fkey")

  @@index([createdAt], map: "WalletTransaction_createdAt_idx")
  @@index([type], map: "WalletTransaction_type_idx")
  @@index([walletId], map: "WalletTransaction_walletId_idx")
}

model wishlist {
  id           String         @id
  buyerId      String
  name         String
  isPublic     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  buyer        buyer          @relation(fields: [buyerId], references: [id], onDelete: Cascade, map: "Wishlist_buyerId_fkey")
  wishlistitem wishlistitem[]

  @@index([buyerId], map: "Wishlist_buyerId_idx")
  @@index([isPublic], map: "Wishlist_isPublic_idx")
}

model wishlistitem {
  id         String   @id
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())
  product    product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "WishlistItem_productId_fkey")
  wishlist   wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade, map: "WishlistItem_wishlistId_fkey")

  @@unique([wishlistId, productId], map: "WishlistItem_wishlistId_productId_key")
  @@index([productId], map: "WishlistItem_productId_idx")
  @@index([wishlistId], map: "WishlistItem_wishlistId_idx")
}

enum orderstatushistory_status {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum wallettransaction_type {
  EARNING
  WITHDRAWAL
  REFUND
  COMMISSION
}

enum payoutrequest_status {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum subscription_status {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum order_status {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum user_role {
  ADMIN
  SELLER
  BUYER
}

enum payment_status {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum product_condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}
